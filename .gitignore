# ============================================================
# Python
# ============================================================
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.ipynb_checkpoints/

# ============================================================
# Dataset and feature CSVs — too big for git
# ============================================================
data/
features.csv
features_split.csv
features_smoke.csv
features_top*.csv
*.parquet

# Allow small reference CSVs in a docs/ folder if you ever want them
!docs/*.csv

# ============================================================
# Trained models — regenerable from scripts, large
# ============================================================
*.joblib
*.pkl
*.pickle
*.h5
*.onnx

# ============================================================
# Experiment outputs — regenerable
# ============================================================
results_svm/
results_xgb/
results_mlp/
results_featsel/
results_*_reduced/
results_*/

# Keep small summary JSONs and CSVs if you want them version-controlled,
# uncomment to override the results_*/ rule:
# !results_*/*.json
# !results_*/*_per_device_test.csv
# !results_*/*_per_class_test.csv

# ============================================================
# LaTeX build artifacts (if you ever build locally)
# ============================================================
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk
*.bbl
*.blg

# ============================================================
# OS / editor cruft
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*~

# ============================================================
# Secrets / local config (never commit these)
# ============================================================
.env
*.key
secrets.json